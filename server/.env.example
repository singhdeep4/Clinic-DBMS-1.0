# Database Configuration
# IMPORTANT: Update with your actual values in .env file (do NOT commit .env)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=ayurkaya_clinic_db
DB_PORT=3306

# Server Configuration
SERVER_PORT=5000
NODE_ENV=development

# JWT Configuration
# IMPORTANT: Generate a random secure string for production
JWT_SECRET=change_this_to_a_random_secure_string
JWT_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
