rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Queue collection: allow public reads/writes so patients can book slots
    match /queue/{queueId} {
      allow read, write: if true;
    }
    
    // 2. Patients collection: allow public reads to check/verify duplicate registrations,
    // but only the authenticated doctor can add/edit patient records
    match /patients/{patientId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 3. Other collections: restrict entirely to the authenticated doctor portal users
    match /visits/{visitId} {
      allow read, write: if request.auth != null;
    }
    
    match /archived_records/{archiveId} {
      allow read, write: if request.auth != null;
    }
    
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }
    
    match /registry/{registryId} {
      allow read, write: if request.auth != null;
    }
  }
}
