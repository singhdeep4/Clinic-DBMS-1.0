rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Queue collection: allow public reads/writes so patients can book slots
    match /queue/{queueId} {
      allow read, write: if true;
    }
    
    // 2. Patients collection: allow public reads/writes so the admin and portal can manage profiles
    match /patients/{patientId} {
      allow read, write: if true;
    }

    // 3. Doctors collection: allow public reads/writes so the admin can whitelist and verify doctors
    match /doctors/{doctorId} {
      allow read, write: if true;
    }

    // 3.5. Admins collection: allow public reads/writes so systems can login and seed default admin
    match /admins/{adminId} {
      allow read, write: if true;
    }
    
    // 4. Other collections: restrict entirely to the authenticated doctor portal users
    match /visits/{visitId} {
      allow read, write: if request.auth != null;
    }
    
    match /archived_records/{archiveId} {
      allow read, write: if request.auth != null;
    }
    
    match /cases/{caseId} {
      allow read, write: if request.auth != null;
    }
    
    match /registry/{registryId} {
      allow read, write: if request.auth != null;
    }

    // 5. Chats and Prescriptions collections: allow patient & doctor reads/writes
    match /chats/{chatId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    match /prescriptions/{prescriptionId} {
      allow read, write: if true;
    }
  }
}
